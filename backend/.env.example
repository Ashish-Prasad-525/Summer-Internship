# ════════════════════════════════════════════════════════════════
#  AI Document Intelligence System - Environment Configuration
#  Copy this to .env and fill in your values
# ════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── LLM Provider ─────────────────────────────────────────────────
# Options: openai | ollama
# LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

Ollama - local LLM (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Embeddings ────────────────────────────────────────────────────
# Options: openai | huggingface
EMBEDDING_PROVIDER=huggingface

# HuggingFace - runs locally, no API key needed (recommended for free tier)
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# OpenAI embeddings (use when EMBEDDING_PROVIDER=openai)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# ── Vector Store ──────────────────────────────────────────────────
# Options: faiss | chroma
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=./vectorstore/faiss_index
CHROMA_PERSIST_DIR=./vectorstore/chroma_db

# ── RAG Tuning ────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.3
MAX_CONTEXT_TOKENS=4096

# ── File Storage ──────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50

# ── Database ──────────────────────────────────────────────────────
# SQLite (default for local dev)
DATABASE_URL=sqlite:///./data/app.db
# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/rag_db

# ── JWT Auth ──────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
